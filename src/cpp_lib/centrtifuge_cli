# centrifuge_cli.py
"""
Command-line client for the Centrifuge server.

Usage:
    python centrifuge_cli.py ping
    python centrifuge_cli.py info
    python centrifuge_cli.py profiles
    python centrifuge_cli.py diagnostics
    python centrifuge_cli.py initialize --profile "Centrifuge profile"
    python centrifuge_cli.py open_door --bucket 1
    python centrifuge_cli.py close_door
    python centrifuge_cli.py spin --vel 55 --accel 60 --decel 90 --mode 1 --time 10 --bucket 1
    python centrifuge_cli.py stop --bucket 1
    python centrifuge_cli.py close
"""

import socket
import json
import argparse
import sys

HOST = '127.0.0.1'
PORT = 5555


def send_command(command, params=None, host=HOST, port=PORT, timeout=120):
    """Send a command to the centrifuge server and return the result"""
    request = json.dumps({
        "command": command,
        "params": params or {}
    })

    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(timeout)

    try:
        sock.connect((host, port))
        sock.sendall(request.encode('utf-8'))
        sock.shutdown(socket.SHUT_WR)  # Signal we're done sending

        # Read response
        data = b''
        while True:
            chunk = sock.recv(4096)
            if not chunk:
                break
            data += chunk

        result = json.loads(data.decode('utf-8'))
        return result

    except ConnectionRefusedError:
        return {"status": "error",
                "error": "Cannot connect — is centrifuge_server.py running?"}
    except socket.timeout:
        return {"status": "error", "error": "Command timed out"}
    finally:
        sock.close()


def main():
    parser = argparse.ArgumentParser(
        description='Agilent Centrifuge CLI',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Commands:
  ping                          Test server connection
  info                          Get centrifuge status info
  profiles                      List available profiles
  diagnostics                   Open diagnostics dialog (COM port setup)
  initialize -p PROFILE         Connect using named profile
  open_door -b BUCKET           Open door (bucket 1 or 2)
  close_door                    Close door
  spin [options]                Run spin cycle
  stop -b BUCKET                Emergency stop
  close                         Disconnect
  abort                         Abort error state
  retry                         Retry last failed action
  ignore                        Ignore current error
  last_error                    Get last error message
  hardware_version              Get hardware version
        """
    )

    parser.add_argument('command', help='Command to execute')
    parser.add_argument('-p', '--profile', help='Profile name')
    parser.add_argument('-b', '--bucket', type=int, default=1,
                        help='Bucket number (1-2)')
    parser.add_argument('--vel', type=float, default=50.0,
                        help='Velocity %% (1-100)')
    parser.add_argument('--accel', type=float, default=100.0,
                        help='Acceleration %% (1-100)')
    parser.add_argument('--decel', type=float, default=100.0,
                        help='Deceleration %% (1-100)')
    parser.add_argument('--mode', type=int, default=0,
                        help='Timer mode: 0=total, 1=at_speed, 2=continuous')
    parser.add_argument('--time', type=int, default=60,
                        help='Time in seconds (1-86400)')
    parser.add_argument('--host', default=HOST, help='Server host')
    parser.add_argument('--port', type=int, default=PORT, help='Server port')

    args = parser.parse_args()

    # Build params based on command
    params = {}
    if args.command == 'initialize':
        if not args.profile:
            print("Error: --profile required for initialize")
            sys.exit(1)
        params['profile_name'] = args.profile
    elif args.command in ('open_door', 'stop'):
        params['bucket_num'] = args.bucket
    elif args.command == 'spin':
        params = {
            'vel_percent': args.vel,
            'accel_percent': args.accel,
            'decel_percent': args.decel,
            'timer_mode': args.mode,
            'time_seconds': args.time,
            'bucket_num': args.bucket,
        }

    result = send_command(args.command, params, args.host, args.port)

    # Pretty print
    print(json.dumps(result, indent=2))

    # Exit code
    sys.exit(0 if result.get('status') == 'ok' else 1)


if __name__ == '__main__':
    main()